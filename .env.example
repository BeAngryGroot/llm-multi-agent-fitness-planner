# Project Configuration
PROJECT_NAME=ai-fitness-planner
VERSION=0.0.1
ENVIRONMENT=development

# Database Configuration
DB_USER=groot
DB_PASSWORD=1245
DB_NAME=ai_fitness_planner
DB_HOST=ai_fitness_planner_db
DB_PORT=5432

# Database URL (update with your credentials)
DATABASE_URL=postgresql://groot:1245@ai_fitness_planner_db:5432/ai_fitness_planner

# External APIs
TONGYI_API_KEY=sk-81a4367fb582428e8181f4d143fa4d43
DASHSCOPE_API_KEY=sk-81a4367fb582428e8181f4d143fa4d43

# MongoDB Configuration
MONGO_USER=groot
